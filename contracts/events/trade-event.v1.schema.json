{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/events/trade-event.v1.schema.json",
  "title": "TradeEventV1",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "symbol",
    "exchange",
    "event_time",
    "ingest_time",
    "sequence_number",
    "price",
    "size"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "event_type": {
      "const": "trade"
    },
    "symbol": {
      "type": "string"
    },
    "exchange": {
      "type": "string"
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "ingest_time": {
      "type": "string",
      "format": "date-time"
    },
    "sequence_number": {
      "type": "integer",
      "minimum": 0
    },
    "price": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "size": {
      "type": "integer",
      "exclusiveMinimum": 0
    },
    "trade_id": {
      "type": "string"
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
